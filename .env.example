# Chain environment switch — the ONLY thing that flips testnet <-> mainnet
NEXT_PUBLIC_CHAIN_ENV=testnet

# Local database (SQLite in dev). For SQLite, Prisma resolves the path relative
# to prisma/schema.prisma, so this file lives at prisma/dev.db.
DATABASE_URL="file:./dev.db"

# Server-only secrets (never NEXT_PUBLIC_) — added/used in later waves:
# BASE_SEPOLIA_RPC=
# BASE_MAINNET_RPC=
# ETHERSCAN_API_KEY=
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
