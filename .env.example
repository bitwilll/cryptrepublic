# Chain environment switch — the ONLY thing that flips testnet <-> mainnet
NEXT_PUBLIC_CHAIN_ENV=testnet

# Local database (SQLite in dev). For SQLite, Prisma resolves the path relative
# to prisma/schema.prisma, so this file lives at prisma/dev.db.
DATABASE_URL="file:./dev.db"

# Public app URL (host+origin bound into SIWE messages). No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Keyed RPC endpoints (SERVER-ONLY — never NEXT_PUBLIC_) ---
# The browser NEVER sees these; it calls the allow-listed /api/rpc/[chain] proxy.
# One env var per active EVM chain (see config/chains.config.ts serverRpcEnv).
RPC_BASE_SEPOLIA=
RPC_BASE=
RPC_ETHEREUM=
RPC_ARBITRUM=
RPC_OPTIMISM=
RPC_POLYGON=
# Keyed Solana RPC (SERVER-ONLY) — proxied via /api/rpc/solana.
RPC_SOLANA=

# Tx history via Etherscan API v2 (multichain, single key) — SERVER-ONLY,
# proxied via /api/history/[chain].
ETHERSCAN_API_KEY=

# WalletConnect v2 project id — this is a PUBLIC client id (safe to expose).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
