// ─────────────────────────────────────────────────────────────────────────────
// POSTGRES DEPLOYMENT TARGET (Vercel production) — MIRROR of ../schema.prisma.
//
// prisma/schema.prisma (sqlite) stays AUTHORITATIVE for local dev + the local
// test suite. This file must define an IDENTICAL datamodel — only the
// datasource block differs (provider + directUrl). Enforced by
// prisma/schema-drift.test.ts: edit BOTH files together or the unit suite
// fails.
//
// - `url` is the runtime connection string (on Vercel: the POOLED Neon URL).
// - `directUrl` is used ONLY by Prisma CLI commands (migrate deploy) that need
//   a direct, non-pooled connection. The Neon/Vercel integration sets
//   DATABASE_URL_UNPOOLED automatically; for a plain Postgres set it to the
//   same value as DATABASE_URL. See docs/DEPLOY_VERCEL.md.
//
// Migrations live in ./migrations (postgres dialect), generated with
// `prisma migrate diff --from-empty --to-schema-datamodel` — see
// docs/DEPLOY_VERCEL.md for the regeneration procedure after schema changes.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

/// INVARIANT: no model may ever store a private key, seed phrase, or plaintext password.
/// Enums are String columns with app-level union types (lib/auth/types.ts) for SQLite/Postgres portability.

model User {
  id               String    @id @default(cuid())
  email            String?   @unique // lowercased before write; null for SIWE-only users
  passwordHash     String? // Argon2id encoded string; null for SIWE-only. NEVER plaintext.
  name             String? // DIVERGENCE: spec §4.2 calls this `displayName`; we use `name` this wave.
  kycStatus        String    @default("NONE") // KycStatus union
  role             String    @default("USER") // UserRole union (USER|ADMIN) — lib/auth/types.ts
  suspendedAt      DateTime? // admin suspension (Wave 9) — DISTINCT from the login-lockout lockedUntil
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sessions      Session[]
  linkedWallets LinkedWallet[]
  application   CitizenshipApplication?

  referralTokenBalance Int @default(0) // admin-allocated referral quota; consumed on referral when trust <= 50
  trustAdjustment      Int @default(0) // admin signed delta folded into the hybrid trust score (clamped 0..100)

  referralsMade     Referral[] @relation("ReferralsMade")
  referralsReceived Referral[] @relation("ReferralsReceived")

  passkey2faEnabled   Boolean              @default(false) // Wave 14 — require a passkey to complete password sign-in
  webauthnCredentials WebAuthnCredential[]

  storeListings         StoreListing[]         @relation("StoreListings")
  storeInquiries        StoreInquiry[]         @relation("StoreInquiries")
  certificates          SignedCertificate[]    @relation("Certificates")
  bitwills              BitwillDirective[]     @relation("Bitwills")
  insuranceApplications InsuranceApplication[] @relation("InsuranceApplications")
  commissaryInterests   CommissaryInterest[]   @relation("CommissaryInterests")
  fundraisingProjects   FundraisingProject[]   @relation("FundraisingProjects")
  investmentPledges     InvestmentPledge[]     @relation("InvestmentPledges")
  projectEndorsements   ProjectEndorsement[]   @relation("ProjectEndorsements")
  officeAppointments    OfficeAppointment[]    @relation("OfficeAppointments")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique // sha256(raw cookie token)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?
  ipHash    String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

model SiweNonce {
  id        String    @id @default(cuid())
  nonce     String    @unique
  address   String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

/// A cross-device wallet-QR LOGIN challenge (Wave 13). Public relay row only —
/// never a key/seed. `nonce` == the SIWE nonce device B signs (single-use);
/// `matchCode` is shown on both devices (anti-phishing). Consumed once the
/// session is issued to device A.
model WalletLoginChallenge {
  id         String    @id @default(cuid())
  nonce      String    @unique
  matchCode  String
  status     String    @default("pending") // pending | approved | consumed
  userId     String? // bound on approve (the wallet's verified user); no FK (relay row)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  consumedAt DateTime?

  @@index([expiresAt])
}

/// A WebAuthn passkey credential (Wave 14). PUBLIC data only — the credential's
/// public key, signature counter, and metadata. The private half never leaves
/// the user's authenticator; the server can never sign as the user.
model WebAuthnCredential {
  id           String    @id @default(cuid())
  credentialId String    @unique // base64url credential ID from the authenticator
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  publicKey    String // base64url COSE public key (public by definition)
  counter      BigInt    @default(0) // uint32 signature counter (clone detection)
  transports   String? // comma-joined AuthenticatorTransport hints
  deviceType   String // singleDevice | multiDevice
  backedUp     Boolean   @default(false)
  label        String? // user-chosen display name
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

/// A single-use WebAuthn ceremony challenge (Wave 14). Mirrors SiweNonce:
/// short-TTL, consumed exactly once; `userId` is set for registration
/// ceremonies (bound to the enrolling session) and null for login ceremonies.
model WebAuthnChallenge {
  id        String    @id @default(cuid())
  challenge String    @unique // base64url challenge issued to the browser
  type      String // registration | authentication
  userId    String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

model LinkedWallet {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // DIVERGENCE: spec §4.2 uses a composite @@unique([chainFamily, address]); v1 is EVM-only so we
  // use a plain address @unique. Wave 3 (multi-chain) must migrate to the composite key.
  address    String    @unique // checksummed EVM address
  chain      String    @default("EVM") // ChainFamily union (spec calls this `chainFamily`)
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model CitizenshipApplication {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  status String @default("DRAFT") // ApplicationStatus union
  // DIVERGENCE: spec §4.2 names these declaredName / declaredCity / declaredCountry;
  // this wave uses name / domicileCity / hostCountry (+ motto). Later waves must reconcile.
  name           String?
  domicileCity   String?
  hostCountry    String?
  motto          String?
  oathAcceptedAt DateTime?
  kycStatus      String    @default("NONE") // KycStatus union
  // --- Wave 5 (mint) additions. ALL PUBLIC data — never a key/seed. ---
  // The verified LinkedWallet/embedded EVM address bound at witness-request time
  // (applicant-binding rule). PUBLIC address, not a secret.
  applicantAddress String?
  // The on-chain applicant nonce + deadline captured at witness-request time
  // (stringified bigints), used to reject stale sigs and to reconstruct the exact
  // attestations[] at seal time.
  witnessNonce    String?
  witnessDeadline String?
  // Client-reported cache of the sealed mint (authoritative source is the chain,
  // reconciled by PassportView via readPassportStatus).
  sealTxHash     String?
  citizenTokenId String?
  sealedAt       DateTime?
  reviewNote     String? // admin review note (Wave 9) — off-chain only, never chain state
  // --- Wave 10 (admin-mint override). OFF-CHAIN INTENT, never chain truth. ---
  adminApprovedAt DateTime? // admin-mint override APPROVAL time (Wave 10) — citizen state stays chain-derived
  adminApprovedBy String? // the admin userId who approved (Wave 10) — off-chain intent only
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  witnessSignatures WitnessSignature[]

  @@index([status])
}

/// One collected EIP-712 witness signature over an applicant's Attestation. ALL
/// columns are PUBLIC data (a checksummed address + an EIP-712 signature + the
/// nonce/deadline the sig is bound to) — never a key, seed, or password.
model WitnessSignature {
  id             String                 @id @default(cuid())
  applicationId  String
  application    CitizenshipApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  witnessAddress String // checksummed EVM address (recovered on submit)
  signature      String // 0x EIP-712 signature (PUBLIC data, not a secret)
  nonce          String // the applicant on-chain nonce this sig is bound to
  deadline       String // unix seconds (stringified)
  createdAt      DateTime               @default(now())

  @@unique([applicationId, witnessAddress]) // no duplicate witness (mirrors on-chain DuplicateWitness)
  @@index([applicationId])
}

/// A referral edge: a citizen (referrer) vouches for an applicant (referred).
/// Off-chain POLICY only — never citizenship (that stays chain-derived). All of an
/// applicant's witnesses must be their referrers (Wave 12 referral-gated attestation).
/// no model may ever store a private key, seed phrase, or plaintext password.
model Referral {
  id                String   @id @default(cuid())
  referrerUserId    String
  referrer          User     @relation("ReferralsMade", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referredUserId    String
  referred          User     @relation("ReferralsReceived", fields: [referredUserId], references: [id], onDelete: Cascade)
  whenTokenConsumed Boolean  @default(false) // true = create spent a referral token; false = trust>50 bypass
  createdAt         DateTime @default(now())

  @@unique([referrerUserId, referredUserId])
  @@index([referredUserId])
  @@index([referrerUserId])
}

// ─────────────────────────────────────────────────────────────────────────
// Wave 7 — off-chain DASHBOARD CONTENT. ALL PUBLIC content — no secret columns.
// Anything trustless (tallies, proposal state, claimable, treasury balances,
// citizen/census count, dividend/disbursement history) reads from chain, NEVER
// from these models. These hold only off-chain-by-nature content.
// ─────────────────────────────────────────────────────────────────────────

/// Off-chain rich content for an on-chain CryptGovernance proposal. Linked to the
/// on-chain proposalId; tallies + state ALWAYS read from chain, never here.
model GovernanceProposalContent {
  id              String            @id @default(cuid())
  chainId         Int
  proposalId      String // on-chain proposalId (stringified uint256)
  title           String
  tag             String // PROCEDURAL|CULTURAL|FISCAL|CIVIC|TECHNICAL (union)
  body            String // rich text / markdown
  descriptionHash String? // 0x bytes32 — MUST match the on-chain proposal.descriptionHash
  createdAt       DateTime          @default(now())
  comments        ProposalComment[]

  @@unique([chainId, proposalId])
  @@index([chainId, tag])
}

/// A dissent/discussion comment on a proposal (the "Dissent on the floor" thread).
model ProposalComment {
  id                String                    @id @default(cuid())
  proposalRef       GovernanceProposalContent @relation(fields: [proposalContentId], references: [id], onDelete: Cascade)
  proposalContentId String
  authorAddress     String // checksummed EVM address (citizen; verified on-chain at write time)
  citizenTokenId    String? // resolved tokenId (display "Citizen №…")
  body              String
  upvotes           Int                       @default(0)
  createdAt         DateTime                  @default(now())

  @@index([proposalContentId])
}

/// Sovereign-holdings asset register (the mockup ASSETS array). Off-chain by nature.
model AssetCatalogEntry {
  id             String @id @default(cuid())
  ref            String @unique // "RE-001" etc.
  kind           String // re|ip|eq|tr
  name           String
  location       String
  valueUsd       BigInt // whole USD
  yieldBps       Int // 480 = 4.8%
  annualYieldUsd BigInt
  status         String
  acquiredAt     String // freeform ("2024.11.04" / "ongoing")

  @@index([kind])
}

/// Embassy directory (the mockup EMB array). Off-chain by nature.
model EmbassyDirectory {
  code         String @id // "LIS"
  name         String
  neighborhood String
  hours        String
  foundedAt    String
  brandColor   String
  city         String
  country      String
}

/// Per-city census node — coords for the map + top-cities. Per-city population
/// is aggregated LIVE from CitizenshipApplication.domicileCity (minted citizens
/// only); seededCount is a labeled SEEDED SNAPSHOT for demonstrative geography,
/// never merged into the trustless totalCitizens() headline.
model CityCensus {
  code        String  @id // "LIS"
  name        String
  lat         Float
  long        Float
  hasEmbassy  Boolean @default(false)
  seededCount Int     @default(0)
}

/// Treasury allocation TARGETS (the mockup ALLOC array) — governance-ratified
/// intent, NOT live balances. Live balances read from CryptTreasury.balanceOf.
model TreasuryAllocation {
  id        String @id @default(cuid())
  bucket    String @unique // "embassy_ops" — matches an on-chain allocationBps bucket key when set
  label     String
  targetBps Int // 3800 = 38%
  color     String
}

/// Constitution / doctrine text (preamble, Article IV doctrine, etc.).
model ConstitutionText {
  id       String  @id @default(cuid())
  key      String  @unique // "preamble" | "doctrine_art_iv" | "dividend_legal_note"
  title    String
  body     String
  citation String? // "CONSTITUTION ART. IV §1 · RATIFIED MMXXVI"
}

// ─────────────────────────────────────────────────────────────────────────
// Wave 9 — ADMIN back office. ALL PUBLIC data — no secret columns.
// ─────────────────────────────────────────────────────────────────────────

/// Admin audit trail (Wave 9). EVERY admin mutation writes a row IN THE SAME
/// prisma.$transaction as the mutation (lib/admin/audit.ts writeAudit). before/
/// afterJson pass a per-targetType serializer ALLOWLIST — passwordHash/tokenHash
/// can never appear. actorUserId is a plain column (no FK) so audit rows survive
/// user deletion; null actorUserId = the CLI bootstrap (actorLabel "cli").
model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorLabel  String // "admin:<email>" | "cli"
  action      String // dot-namespaced: "user.suspend", "content.asset.update", "flag.upsert", …
  targetType  String // AuditTargetType union (lib/admin/audit.ts)
  targetId    String
  beforeJson  String? // allowlist-serialized JSON snapshot (nullable for creates)
  afterJson   String? // allowlist-serialized JSON snapshot (nullable for deletes)
  ipHash      String? // reserved; null in v1 (no existing app ipHash convention — divergence noted)
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}

/// Feature flags (Wave 9). Missing row => the per-flag DECLARED default
/// (lib/flags/defaults.ts), undeclared key => false. Public read via /api/flags.
model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────
// Wave 15 — CITIZEN SERVICES (store / bitwill / insurance / certificates /
// commissary interest). ALL PUBLIC data — no secret columns. Signatures are
// public attestations (like WitnessSignature); never a key, seed, or password.
// Settlement of any listed price is peer-to-peer on-chain by the citizens
// themselves — the Republic never holds or moves funds.
// ─────────────────────────────────────────────────────────────────────────

/// A citizen-to-citizen marketplace listing (Miro: STORE — user as buyer/seller).
model StoreListing {
  id           String         @id @default(cuid())
  sellerUserId String
  seller       User           @relation("StoreListings", fields: [sellerUserId], references: [id], onDelete: Cascade)
  title        String
  description  String
  category     String // StoreCategory union (lib/services/types.ts)
  priceCoin    String // decimal string, CRPT units — pricing intent only; settlement is peer-to-peer
  status       String         @default("ACTIVE") // ListingStatus union ACTIVE|SOLD|WITHDRAWN|REMOVED
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  inquiries    StoreInquiry[]

  @@index([status])
  @@index([sellerUserId])
}

/// A buyer's inquiry on a listing (in-app message thread seed; no payments).
model StoreInquiry {
  id          String       @id @default(cuid())
  listingId   String
  listing     StoreListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerUserId String
  buyer       User         @relation("StoreInquiries", fields: [buyerUserId], references: [id], onDelete: Cascade)
  message     String
  reply       String? // seller's reply
  status      String       @default("OPEN") // InquiryStatus union OPEN|ANSWERED|CLOSED
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([listingId])
  @@index([buyerUserId])
}

/// A wallet-signed message/document attestation (Miro: Signing Message &
/// Certificate). The signature is produced CLIENT-SIDE by the citizen's own
/// wallet; the server stores only the public record and verifies recovery.
model SignedCertificate {
  id            String    @id @default(cuid())
  serial        String    @unique // human-readable serial ("CR-CERT-…")
  authorUserId  String
  author        User      @relation("Certificates", fields: [authorUserId], references: [id], onDelete: Cascade)
  kind          String // CertificateKind union MESSAGE|DOCUMENT
  title         String
  subject       String // signed message text, or document name for DOCUMENT
  contentHash   String // sha-256 of the signed content (message text / document bytes) (public)
  signerAddress String // checksummed EVM address (public)
  signature     String // 0x signature (public attestation, not a secret)
  createdAt     DateTime  @default(now())
  revokedAt     DateTime?

  @@index([authorUserId])
  @@index([signerAddress])
}

/// A BitWill inheritance directive (Miro: BITWILL — INHERITANCE). A wallet-signed
/// OFF-CHAIN declaration of intent: names a beneficiary for the citizen's estate
/// record. It never holds, moves, or can move funds — it is a signed document.
model BitwillDirective {
  id                 String    @id @default(cuid())
  ownerUserId        String
  owner              User      @relation("Bitwills", fields: [ownerUserId], references: [id], onDelete: Cascade)
  beneficiaryName    String
  beneficiaryContact String // email / citizen no. — supplied by the owner
  beneficiaryAddress String? // optional EVM address (public)
  assetsMemo         String // free-text estate description; NEVER keys or seeds
  directiveHash      String // 0x keccak256 of the canonical directive payload
  signerAddress      String // checksummed EVM address that signed
  signature          String // 0x signature (public)
  status             String    @default("ACTIVE") // DirectiveStatus union ACTIVE|REVOKED|SUPERSEDED
  createdAt          DateTime  @default(now())
  revokedAt          DateTime?

  @@index([ownerUserId])
}

/// A citizen's application for Republic cover (Miro: User Insurance — asset /
/// health). A registry of applications and their review state — no premiums are
/// collected and no funds move through the Republic.
model InsuranceApplication {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("InsuranceApplications", fields: [userId], references: [id], onDelete: Cascade)
  product      String // InsuranceProduct union ASSET|HEALTH
  coverageNote String // what the citizen wants covered
  valueUsd     BigInt? // declared value (whole USD) for asset cover
  status       String   @default("SUBMITTED") // SUBMITTED|IN_REVIEW|APPROVED|DECLINED
  reviewNote   String? // admin note (Wave 9 audit conventions apply)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

/// Register-of-interest for a Commissary (brand kit / merchandise) item. itemId
/// references lib/content/registry.ts COMMISSARY ids — content, not FK.
model CommissaryInterest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("CommissaryInterests", fields: [userId], references: [id], onDelete: Cascade)
  itemId    String
  note      String?
  createdAt DateTime @default(now())

  @@unique([userId, itemId])
  @@index([itemId])
}

/// A citizen fundraising project (Wave 16 — Cabinet direction 2026-07-08). A
/// REGISTRY of proposals and pledges: the Republic never holds, escrows, or
/// moves funds. Direct contributions happen wallet-to-wallet outside the
/// platform, to the creator's declared treasury address.
model FundraisingProject {
  id              String    @id @default(cuid())
  creatorUserId   String
  creator         User      @relation("FundraisingProjects", fields: [creatorUserId], references: [id], onDelete: Cascade)
  title           String
  summary         String
  description     String
  category        String // ProjectCategory union (lib/gov/types.ts)
  goalCoin        String // decimal string, $CRYPT — same grammar as StoreListing.priceCoin
  treasuryAddress String? // optional checksummed EVM address for direct wallet-to-wallet contributions (public)
  status          String    @default("SUBMITTED") // FundraisingStatus union SUBMITTED|ACTIVE|DECLINED|CLOSED|WITHDRAWN
  reviewNote      String? // admin decision note (Wave 9 audit conventions)
  decidedBy       String? // admin userId that approved/declined
  decidedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  pledges      InvestmentPledge[]
  endorsements ProjectEndorsement[]

  @@index([status])
  @@index([creatorUserId])
}

/// A pledge of intent to invest in a project (Wave 16). A recorded COMMITMENT
/// only — no funds are held or transferred by the Republic. One row per
/// citizen per project; withdrawing flips status, re-pledging flips it back.
model InvestmentPledge {
  id         String             @id @default(cuid())
  projectId  String
  project    FundraisingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId     String
  user       User               @relation("InvestmentPledges", fields: [userId], references: [id], onDelete: Cascade)
  amountCoin String // decimal string, $CRYPT
  note       String?
  status     String             @default("PLEDGED") // PledgeStatus union PLEDGED|WITHDRAWN
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([projectId, userId])
  @@index([userId])
}

/// A citizen endorsement of a SUBMITTED project — the community-approval
/// signal (7 endorsements = community-backed, echoing the witness rule).
model ProjectEndorsement {
  id        String             @id @default(cuid())
  projectId String
  project   FundraisingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User               @relation("ProjectEndorsements", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime           @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
}

/// A civic office appointment (Wave 16 bureaucracy — PM, ministers, senators,
/// protectors…). Honours + public display ONLY: grants NO auth privilege;
/// User.role (USER|ADMIN) is untouched and remains the only authz gate.
model OfficeAppointment {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("OfficeAppointments", fields: [userId], references: [id], onDelete: Cascade)
  office      String // CivicOffice union (lib/gov/types.ts)
  portfolio   String? // e.g. "Treasury", "Digital Infrastructure"
  note        String?
  appointedBy String // admin userId
  appointedAt DateTime  @default(now())
  revokedAt   DateTime?
  revokedBy   String? // admin userId

  @@index([userId])
  @@index([office])
}
