# =============================================================================
# CryptRepublic — MAINNET env template (PLACEHOLDERS ONLY — user-completed)
#
# NEVER place a private key, seed phrase, or keystore password in a repo file —
# use a hardware wallet, `cast wallet`, or a keystore reference (spec §8.3
# step 2). Deploy keys are not app config and have no place in ANY .env file.
#
# Copy this file to .env.mainnet (git-ignored) and fill in your own values.
# Do NOT proceed to mainnet before the Pre-Mainnet Gate is satisfied — see
# docs/MAINNET_HANDOFF.md.
# =============================================================================

# Chain environment switch — the ONLY thing that flips testnet <-> mainnet.
# NEXT_PUBLIC_* values are inlined at BUILD time: rebuild after changing.
NEXT_PUBLIC_CHAIN_ENV=mainnet

# Production database. Postgres is recommended; the production DB choice is
# the user's (SQLite is the dev/CI engine — see docs/ENV_REFERENCE.md).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/cryptrepublic

# Public app URL (host+origin bound into SIWE messages + CSRF Origin check).
# No trailing slash.
NEXT_PUBLIC_APP_URL=https://your-production-domain.example

# --- Keyed RPC endpoints (SERVER-ONLY — never NEXT_PUBLIC_) ---
# The browser NEVER sees these; it calls the allow-listed /api/rpc/[chain] proxy.
# Under the mainnet profile these names resolve to: Base mainnet (primary),
# Ethereum, Arbitrum One, OP Mainnet, Polygon PoS (config/chains.config.ts).
RPC_BASE=https://YOUR-BASE-MAINNET-RPC.example/YOUR_KEY
RPC_ETHEREUM=
RPC_ARBITRUM=
RPC_OPTIMISM=
RPC_POLYGON=
# Keyed Solana RPC (SERVER-ONLY) — proxied via /api/rpc/solana.
RPC_SOLANA=

# Tx history via Etherscan API v2 (multichain, single key) — SERVER-ONLY.
ETHERSCAN_API_KEY=YOUR_BASESCAN_ETHERSCAN_V2_KEY

# WalletConnect v2 project id — this is a PUBLIC client id (safe to expose).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
